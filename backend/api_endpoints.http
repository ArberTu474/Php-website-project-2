### ─────────────────────────────────────────────────────────────
### HEALTH
### ─────────────────────────────────────────────────────────────

### Health Check
GET {{baseUrl}}/health


### ─────────────────────────────────────────────────────────────
### AUTH
### ─────────────────────────────────────────────────────────────

### Register Teacher
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "ana@test.com",
  "password": "secret123",
  "first_name": "Ana",
  "last_name": "Koci",
  "role": "teacher"
}

###

### Register Student
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "student@test.com",
  "password": "secret123",
  "first_name": "Besa",
  "last_name": "Hoxha",
  "role": "student"
}

###

### Login Teacher
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "ana@test.com",
  "password": "secret123"
}

###

### Login Student
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "student@test.com",
  "password": "secret123"
}

###

### Get Current User (me)
GET {{baseUrl}}/auth/me
Authorization: Bearer {{teacherToken}}


### ─────────────────────────────────────────────────────────────
### COURSES
### ─────────────────────────────────────────────────────────────

### List All Published Courses (public)
GET {{baseUrl}}/courses

###

### Get Single Course by ID (public)
GET {{baseUrl}}/courses/{{courseId}}

###

### Create Course (teacher)
POST {{baseUrl}}/courses
Content-Type: application/json
Authorization: Bearer {{teacherToken}}

{
  "title": "Intro to PHP",
  "description": "Learn PHP from scratch",
  "is_published": true
}

###

### Update Course (teacher owner)
PUT {{baseUrl}}/courses/{{courseId}}
Content-Type: application/json
Authorization: Bearer {{teacherToken}}

{
  "title": "Intro to PHP — Updated",
  "description": "Updated description",
  "is_published": true
}

###

### Delete Course (teacher owner)
DELETE {{baseUrl}}/courses/{{courseId}}
Authorization: Bearer {{teacherToken}}


### ─────────────────────────────────────────────────────────────
### MODULES
### ─────────────────────────────────────────────────────────────

### Add Module to Course (teacher owner)
POST {{baseUrl}}/courses/{{courseId}}/modules
Content-Type: application/json
Authorization: Bearer {{teacherToken}}

{
  "title": "Getting Started",
  "description": "Setup and basics"
}

###

### Update Module (teacher owner)
PUT {{baseUrl}}/modules/{{moduleId}}
Content-Type: application/json
Authorization: Bearer {{teacherToken}}

{
  "title": "Getting Started — Updated",
  "description": "Updated description"
}

###

### Delete Module (teacher owner)
DELETE {{baseUrl}}/modules/{{moduleId}}
Authorization: Bearer {{teacherToken}}


### ─────────────────────────────────────────────────────────────
### LESSONS
### ─────────────────────────────────────────────────────────────

### Add Lesson to Module (teacher owner)
POST {{baseUrl}}/modules/{{moduleId}}/lessons
Content-Type: application/json
Authorization: Bearer {{teacherToken}}

{
  "title": "What is PHP?",
  "content": "## Introduction\n\nPHP is a server-side scripting language.",
  "duration_mins": 10
}

###

### Update Lesson (teacher owner)
PUT {{baseUrl}}/lessons/{{lessonId}}
Content-Type: application/json
Authorization: Bearer {{teacherToken}}

{
  "title": "What is PHP? — Updated",
  "content": "## Introduction\n\nUpdated content here.",
  "duration_mins": 12
}

### Get single lesson (student, enrolled)
GET {{baseUrl}}/lessons/{{lessonId}}
Authorization: Bearer {{studentToken}}


### ─────────────────────────────────────────────────────────────
### ENROLLMENTS & PROGRESS
### ─────────────────────────────────────────────────────────────

### Enroll in Course (student)
POST {{baseUrl}}/courses/{{courseId}}/enroll
Authorization: Bearer {{studentToken}}

###

### Mark Lesson Complete (student)
POST {{baseUrl}}/lessons/{{lessonId}}/complete
Authorization: Bearer {{studentToken}}

###

### Get My Enrollments + Progress (student)
GET {{baseUrl}}/enrollments/me
Authorization: Bearer {{studentToken}}


### ─────────────────────────────────────────────────────────────
### REVIEWS
### ─────────────────────────────────────────────────────────────

### Leave a Review (student — needs 80% completion)
POST {{baseUrl}}/enrollments/{{enrollmentId}}/review
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "rating": 5,
  "comment": "Great course!"
}